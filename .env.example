# Copia este archivo como ".env" (sin el ".example") y rellena tus datos
# reales de Aiven. El archivo ".env" NUNCA se sube a GitHub (ya está en
# .gitignore) — cada quien en el equipo tiene el suyo con sus propias
# credenciales, o comparten las mismas por WhatsApp/Discord, pero nunca
# las pegan directo en el código.

DB_HOST=tu-host-de-aiven.aivencloud.com
DB_PORT=puerto_de_aiven
DB_USER=avnadmin
DB_PASSWORD=tu_clave_de_aiven
DB_NAME=defaultdb

# Ruta al certificado CA que descargas de Aiven (ver "Certificado de CA"
# en los detalles de conexión de tu servicio). Guárdalo como ca.pem en
# la raíz del proyecto — el certificado en sí NO es secreto, se puede
# subir a GitHub sin problema.
DB_SSL_CA=ca.pem
